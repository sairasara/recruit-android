<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#C1C2C2">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp">
        <TextView
            android:id="@+id/summaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="summary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/creditDebitText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Credit/Debit "
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_alignParentEnd="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_below="@+id/summaryText"
            app:cardBackgroundColor="#C1C2C2">

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginVertical="8dp"/>

            <TextView
                android:id="@+id/toPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To:"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_marginTop="5dp"/>

            <TextView
                android:id="@+id/toValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="To value"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_marginTop="5dp"/>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"/>

            <TextView
                android:id="@+id/amountPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount:"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_marginTop="5dp" />

            <TextView
                android:id="@+id/amountValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Amount Value"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_marginTop="5dp" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"/>

            <TextView
                android:id="@+id/gstPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GST:"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_marginTop="5dp" />

            <TextView
                android:id="@+id/gstValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="GST Value"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_marginTop="5dp" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"/>

            <TextView
                android:id="@+id/transactionDatePlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transaction Date:"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_marginTop="5dp" />

            <TextView
                android:id="@+id/transactionDateValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Transaction Date Value"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_marginTop="5dp" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="8dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_talkback"/>

            <TextView
                android:id="@+id/chatbotText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Talk to us"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_margin="5dp"/>

        </LinearLayout>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>